# Vaultwarden backup job
VAULTWARDEN_DIR=/root/Vaultwarden
DATA_DIR=/root/Vaultwarden/data
BACKUP_ROOT=/root/backups/vaultwarden
KEEP_LOCAL_DAYS=14
REMOTE_KEEP_DAYS=30
HOST_TAG=onecloud

# Delivery toggles
ENABLE_MAIL=1
ENABLE_ONEDRIVE=1
ENABLE_ALERT_ON_FAILURE=1
MAIL_MAX_BYTES=20971520
GITHUB_DISPATCH_ENABLED=0
GITHUB_DISPATCH_REPO=suwei8/OneCloud-Armbian
GITHUB_DISPATCH_TOKEN=
GITHUB_DISPATCH_EVENT=onecloud-backup-uploaded

# SMTP sender
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=example@outlook.com
SMTP_PASSWORD=replace-with-app-password-or-smtp-password
SMTP_FROM=example@outlook.com
SMTP_TO=your-gmail@example.com
SMTP_SSL=0
SMTP_STARTTLS=1

# Optional IMAP sent-folder cleanup
IMAP_CLEAN_SENT=0
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_SENT_FOLDERS=Sent Messages,已发送,&XfJT0ZAB-

# rclone target
RCLONE_REMOTE=onedrive:
RCLONE_DEST_PATH=OneCloudBackups/Vaultwarden
MAILER_SCRIPT=/usr/local/sbin/send_backup_email.py
GITHUB_DISPATCH_SCRIPT=/usr/local/sbin/onecloud_github_dispatch.sh
